    {
      "name": "get products- list",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Статус код 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Время ответа меньше 2000 мс\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "pm.test(\"Ответ содержит массив товаров\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.Items).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"Список товаров не пустой\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.Items.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Первый товар содержит поле id\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.Items[0]).to.have.property(\"id\");\r",
              "});\r",
              "\r",
              "pm.test(\"Первый товар содержит поле title\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.Items[0]).to.have.property(\"title\");\r",
              "});\r",
              "\r",
              "pm.test(\"Первый товар содержит поле price\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.Items[0]).to.have.property(\"price\");\r",
              "});\r",
              "\r",
              "pm.test(\"Цена первого товара является числом\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.Items[0].price).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
